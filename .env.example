# =============================================================================
# Bharat Ticker — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Application ---
APP_NAME=bharat-ticker
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RATE_LIMIT_PER_MINUTE=120
# CORS allowed origins (comma-separated). Leave empty in dev (DEBUG=true → allows
# all). In production set this to the superbrain origin(s) so cross-origin fetches
# aren't blocked, e.g. CORS_ORIGINS=https://your-superbrain.code.run  (or "*").
CORS_ORIGINS=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_TICK_TTL_SECONDS=5
REDIS_DEPTH_TTL_SECONDS=2
REDIS_META_TTL_SECONDS=86400

# --- TimescaleDB (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://bharat:ticker@localhost:5432/bharat_ticker
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# --- Scraping Engine ---
SCRAPE_INTERVAL_SECONDS=1.0
SCRAPE_CONCURRENCY=10
SCRAPE_TIMEOUT_SECONDS=10
SESSION_REFRESH_INTERVAL_SECONDS=90

# --- Proxy Configuration ---
# Comma-separated list of proxies: http://user:pass@host:port
PROXY_LIST=
PROXY_ROTATION_STRATEGY=round_robin
PROXY_HEALTH_CHECK_INTERVAL=60

# --- Circuit Breaker ---
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_SECONDS=30
CB_HALF_OPEN_MAX_CALLS=3

# --- NSE Scraper (Tier-1) ---
NSE_BASE_URL=https://www.nseindia.com
NSE_ENABLED=true

# --- BSE Scraper (Tier-1) ---
BSE_BASE_URL=https://www.bseindia.com
BSE_ENABLED=true

# --- Fyers WebSocket (Tier-2) ---
FYERS_ENABLED=false
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_REDIRECT_URI=
FYERS_ACCESS_TOKEN=

# --- Angel One SmartAPI (Tier-2) ---
ANGEL_ENABLED=false
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# --- Yahoo Finance (Tier-3) ---
YAHOO_ENABLED=true

# --- EODHD (Tier-3) ---
EODHD_ENABLED=false
EODHD_API_KEY=

# --- Alerts ---
ALERT_ENABLED=true

# Slack
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#market-alerts

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Generic Webhook
ALERT_WEBHOOK_URL=

# --- Stock Universe ---
# Options: NIFTY50, NIFTY100, NIFTY200, NIFTY500, ALL_NSE, ALL_BSE, CUSTOM
STOCK_UNIVERSE=NIFTY50
# Comma-separated symbols for CUSTOM universe
CUSTOM_SYMBOLS=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK

# --- /sb Hot-Universe Warm Cache (#7) ---
# A background loop batch-refreshes these symbols every SB_WARM_INTERVAL_S during
# market hours so /sb/quotes sweeps hit warm memory (~5ms) instead of re-scraping
# each poll. DORMANT unless SB_WARM_SYMBOLS is set (or a WATCHLIST is active — the
# warm set unions the recorder's watchlist). TTL is bounded so a served warm quote
# never outlives its freshness window. SB_WARM_FAST=true → price-only sweep (leanest);
# false → also backfill the session open (heavier). Status: GET /api/v1/sb/warm.
SB_WARM_SYMBOLS=
SB_WARM_INTERVAL_S=5
# SB_WARM_TTL_S defaults to 2× the interval; SB_WARM_FAST defaults to true.
SB_WARM_TTL_S=
SB_WARM_FAST=true
